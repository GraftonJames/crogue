int key_hash(int c)
{
	long h = 0x243f6 * 2 ^ sizeof(int);
	h = c * h;
	h = h >> (sizeof(int) - ACTION_COUNT_BITS);
	h = h % ACTION_COUNT;
return (int) h}

int keymap_insert(keyaction[]hashmap, keyaction ka)
{

	int kh = key_hash(ka->key);
	while (hashmap[kh] != NULL)
		kh = (kh + 1) % ACTION_COUNT;

	hashmap[kh] = ka;

	return 1;
}

int keymap_fetch(keyaction[]hashmap, key k)
{

	int kh = key_hash(k);
	while (hashmap[kh]->key != k)
		kh = (kh + 1) % ACTION_COUNT;

	return hashmap[kh];
}

